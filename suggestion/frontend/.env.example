# Frontend Environment Variables

# API URL - Backend API endpoint
# Development: Uses localhost backend
VITE_API_URL=http://localhost:3000/api

# For ngrok remote access, update this to your backend ngrok URL:
# VITE_API_URL=https://your-backend-url.ngrok-free.app/api

# For production (Vercel), set this in Vercel dashboard environment variables:
# VITE_API_URL=https://finalthreecon-api-XXXXXX-uc.a.run.app/api
