# Production Environment Variables Template
# These values are stored in GCP Secret Manager and injected into Cloud Run at runtime
# This file serves as documentation for required environment variables

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Cloud SQL MySQL connection string with private IP
# Format: mysql://USER:PASSWORD@PRIVATE_IP:3306/DATABASE_NAME
# Example: mysql://root:MySecurePassword123@10.1.2.3:3306/clocktower_production
DATABASE_URL="mysql://USER:PASSWORD@CLOUD_SQL_PRIVATE_IP:3306/DATABASE_NAME"

# ============================================================================
# REDIS CONFIGURATION (Memorystore or Upstash)
# ============================================================================
# Memorystore Redis private IP (from VPC) OR Upstash Redis host
REDIS_HOST="MEMORYSTORE_PRIVATE_IP_OR_UPSTASH_HOST"
REDIS_PORT=6379
REDIS_PASSWORD=""  # Empty for Memorystore, set for Upstash

# ============================================================================
# APPLICATION SECRETS
# ============================================================================
# JWT secret for authentication (generate with: openssl rand -base64 32)
JWT_SECRET="GENERATE_SECURE_SECRET_FOR_PRODUCTION"
JWT_EXPIRES_IN=7d

# ============================================================================
# TABLETOP.EVENTS API CONFIGURATION
