# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV="production"
PORT=8080  # Cloud Run sets this automatically

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Your Vercel frontend URL
CORS_ORIGIN="https://your-frontend.vercel.app"

# ============================================================================
# WORKER MODE (Worker Service Only)
# ============================================================================
# Set to "true" for the worker service to only run Bull queue processor
# Leave unset or "false" for API service
# WORKER_ONLY=true

